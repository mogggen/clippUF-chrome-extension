{
  "manifest_version": 3,
  "name": "Clipp – Rabattkoder",
  "version": "1.0.0",
  "description": "Hitta och tillämpa rabattkoder automatiskt",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
