{
  "manifest_version": 3,
  "name": "ClippUF - Allting rabattkoder",
  "version": "0.0.1",
  "description": "Hitta, lagra och tillämpa rabattkoder automatiskt",
  "permissions": ["activeTab", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
